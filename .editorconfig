root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.go]
indent_style = tab
indent_size = 4

[go.{mod,sum}]
indent_style = tab

[{Makefile,justfile,.justfile}]
indent_style = tab

# Two trailing spaces are a hard line break in Markdown.
[*.md]
trim_trailing_whitespace = false

[*.sh]
indent_style = tab
indent_size = 4
