database "posthog" {
  table "events" {
    order_by = ["team_id", "timestamp"]
    column "uuid" {
      type = "UUID"
    }
    column "team_id" {
      type = "Int64"
    }
    column "timestamp" {
      type = "DateTime"
    }
    column "event" {
      type = "String"
    }
    column "properties" {
      type = "String"
    }
    column "region" {
      type = "LowCardinality(String)"
    }
    engine "merge_tree" {
    }
  }

  table "events_daily" {
    order_by = ["team_id", "day"]
    column "team_id" {
      type = "Int64"
    }
    column "day" {
      type = "Date"
    }
    column "events" {
      type = "UInt64"
    }
    engine "merge_tree" {
    }
  }

  table "system_metrics" {
    order_by = ["metric", "timestamp"]
    column "metric" {
      type = "LowCardinality(String)"
    }
    column "timestamp" {
      type = "DateTime"
    }
    column "value" {
      type = "Float64"
    }
    engine "merge_tree" {
    }
  }

  materialized_view "events_daily_mv" {
    to_table = "posthog.events_daily"
    query    = <<SQL
SELECT team_id, toDate(timestamp) AS day, count() AS events
FROM posthog.events
GROUP BY
  team_id, day
SQL

  }
}
